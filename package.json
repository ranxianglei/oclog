{
  "name": "@ranxianglei/oclog",
  "version": "0.1.7",
  "description": "OpenCode session log viewer — tail, follow, and export session logs",
  "type": "module",
  "main": "dist/cli.mjs",
  "bin": {
    "oclog": "dist/cli.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "log-viewer",
    "tail",
    "cli",
    "session",
    "terminal"
  ],
  "license": "MIT",
  "author": "ranxianglei",
  "homepage": "https://github.com/ranxianglei/oclog#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ranxianglei/oclog.git"
  },
  "bugs": {
    "url": "https://github.com/ranxianglei/oclog/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "marked": "^12.0.2",
    "marked-terminal": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
